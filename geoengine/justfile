mod common '../common.justfile'

_default:
    @just --list

# Install dependencies such as llvm-cov.
[group("install")]
install:
    cargo install --locked cargo-llvm-cov
    cargo install --locked cargo-edit
    cargo install --locked git-cliff
    cargo install --locked request-logging-proxy

# Generate OpenAPI specification as JSON file. The file is generated in the current directory.
[group("build")]
generate-openapi-spec: common::_clear
    cargo run --bin geoengine-cli -- openapi > ../openapi.json

# Run lints.
[group("lint")]
lint: common::_clear lint-rustfmt lint-clippy lint-sql

# Run clippy for all features and all targets.
[arg('fix', long='fix', value='--fix', help='Automatically apply fixes where possible.')]
[group("lint")]
lint-clippy fix="": common::_clear
    cargo clippy --all-features --all-targets {{ if fix == "--fix" { "--fix --allow-dirty" } else { "" } }}

# Run rustfmt
[arg('write', long='write', value='--write', help='Write changes to files instead of checking.')]
[group("lint")]
lint-rustfmt write="": common::_clear
    cargo fmt --all -- {{ if write == "--write" { "" } else { "--check" } }}

# Run sqlfluff.
[group("lint")]
lint-sql: common::_clear
    pipx run sqlfluff==4.2.2 lint

# Build in dev or release mode.
[arg('mode', pattern='|--release')]
[group("build")]
build mode="":
    cargo build --locked {{ mode }} --verbose

# Run tests and generate lcov exactly as in CI test action.
[group("ci")]
test-coverage output_path="lcov.info":
    service postgresql start
    cargo llvm-cov \
    	--locked \
    	--all-features \
    	--profile ci \
    	--lcov \
    	--output-path {{ output_path }}

[group("ci")]
test-coverage-services filter="": common::_clear
    cargo llvm-cov \
    	--locked \
    	--all-features \
        --package geoengine-services \
    	--profile ci \
    	--html \
        -- {{ filter }}

# Run the application.
[group("run")]
run: common::_clear
    cargo run

# Run the CLI
[group("run")]
cli *parameters: common::_clear
    cargo run --bin geoengine-cli -- {{ parameters }}

# Run the tests. Optionally, a filter can be provided to run only a subset of the tests.
[group("test")]
test filter="": common::_clear
    cargo test -- {{ filter }} --nocapture

