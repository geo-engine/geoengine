mod common '../common.justfile'

_default:
    @just --list

# Install dependencies such as llvm-cov.
[group("install")]
install:
    cargo install --locked cargo-llvm-cov
    cargo install --locked cargo-edit
    cargo install --locked git-cliff

# Generate OpenAPI specification as JSON file. The file is generated in the current directory.
[group("build")]
generate-openapi-spec: common::_clear
    cargo run --bin geoengine-cli -- openapi > ../openapi.json

# Run lints.
[group("lint")]
lint: common::_clear lint-rustfmt lint-clippy lint-sql

# Run clippy for all features and all targets.
[group("lint")]
lint-clippy: common::_clear
    cargo clippy --all-features --all-targets

# Run rustfmt
[group("lint")]
lint-rustfmt: common::_clear
    cargo fmt --all -- --check

# Run sqlfluff.
[group("lint")]
lint-sql: common::_clear
    pipx run sqlfluff==4.0.4 lint

# Build in dev or release mode.
[arg('mode', pattern='|--release')]
[group("build")]
build mode="":
    cargo build --locked {{ mode }} --verbose

# Run tests and generate lcov exactly as in CI test action.
[group("ci")]
test-coverage output_path="lcov.info":
    service postgresql start
    cargo llvm-cov \
    	--locked \
    	--all-features \
    	--profile ci \
    	--lcov \
    	--output-path {{ output_path }}

# Run the application.
[group("run")]
run: common::_clear
    cargo run

# Run the CLI
[group("run")]
cli *parameters: common::_clear
    cargo run --bin geoengine-cli -- {{ parameters }}

# Run the tests. Optionally, a filter can be provided to run only a subset of the tests.
[group("test")]
test filter="": common::_clear
    cargo test -- {{ filter }} --nocapture

# Run the tests for the geoengine-services package. Optionally, a filter can be provided to run only a subset of the tests. Example: just test-services workflows::workflow::tests
[group("test")]
test-services filter="": common::_clear
    cargo test --package geoengine-services -- {{ filter }} --nocapture

# Run the tests for the geoengine-macros package. Optionally, a filter can be provided to run only a subset of the tests. Example: just test-macros workflows::workflow::tests
[group("test")]
test-macros filter="": common::_clear
    cargo test --package geoengine-macros -- {{ filter }} --nocapture

# Run doctests
[group("test")]
test-doc:
    cargo test --doc --all-features --profile ci --locked

# Show module after macro expansion. Example: just expand-macro geoengine-services api::handlers::ogc::error
[group("debug")]
expand-macro crate macro_path:
    cargo expand --locked -p {{ crate }} --lib {{ macro_path }}

[group("run")]
[script("bash")]
validate-ogc-compliance: common::_clear
    # 1. Start the cargo server in the background
    GEOENGINE__SESSION__FIXED_SESSION_ID=00000000-0000-0000-a000-000000000000 \
    cargo run & CARGO_PID=$!

    # 2. Trap exits (success or failure) to kill the server process
    trap 'kill $CARGO_PID 2>/dev/null || true' EXIT

    # 3. Poll the port until it is active (Change 8080 to your actual port)
    echo "Waiting for Rust server to spin up..."
    while ! nc -z localhost 3030; do 
        sleep 0.5
    done
    echo "Server is up! Starting compliance validation..."

    # 4. Get session and register processing graph
    SESSION_TOKEN=$(curl -s -X POST http://localhost:3030/api/anonymous | jq -r '.id')
    PROCESSING_GRAPH_ID=$(curl -s -X POST http://localhost:3030/api/workflow \
        -H "Authorization: Bearer $SESSION_TOKEN" \
        -H "Content-Type: application/json" \
        -d '{ "type": "Raster", "operator": { "type": "GdalSource", "params": {"data": "ndvi"} } }' | jq -r '.id')
    echo "Got session token: $SESSION_TOKEN"
    echo "Registered processing graph with ID: $PROCESSING_GRAPH_ID"

    # 5. Run the OGC compliance validation action
    cd ../.ogc-validator

    cp .env.template .env
    sed -i "s|\$PROCESSING_GRAPH_ID|$PROCESSING_GRAPH_ID|g" .env

    npm install
    npx @github/local-action ./node_modules/ogc-validator src/main.ts .env
